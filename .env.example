# Polymarket 自动交易系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 钱包私钥（真实交易必需）
# 从MetaMask导出：账户详情 → 导出私钥
PRIVATE_KEY=your_wallet_private_key_here

# API凭证（L2 身份验证）
# 如果没有，程序会尝试使用私钥自动创建
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
PASSPHRASE=your_passphrase_here

# 签名类型配置
# 0: EOA（标准以太坊钱包）
# 1: POLY_PROXY（Magic Link 代理钱包）
# 2: GNOSIS_SAFE（多签代理钱包，最常见）
SIGNATURE_TYPE=2

# Funder 地址（资金地址）
# 从 https://polymarket.com/settings 获取
FUNDER_ADDRESS=your_funder_address_here

# 链ID（137=Polygon）
CHAIN_ID=137

# 交易参数（可选，也可以在程序中配置）
INITIAL_BALANCE=120.0
INITIAL_POSITION=10.0
ENTRY_PRICE=75.0
STOP_LOSS=45.0
TAKE_PROFIT=95.0
TRADE_CYCLE_MINUTES=5

# 日志配置
LOG_LEVEL=INFO
LOG_TO_FILE=true
