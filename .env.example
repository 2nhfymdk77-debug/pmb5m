# Polymarket 自动交易配置

# ==================== 钱包配置 ====================
# 私钥（签名密钥）
PRIVATE_KEY=

# 签名类型:
#   0 = EOA (普通 MetaMask 钱包，私钥直接对应地址)
#   1 = POLY_PROXY (Magic Link 代理钱包)
#   2 = GNOSIS_SAFE (Safe 多签钱包，需要设置 FUNDER_ADDRESS)
SIGNATURE_TYPE=2

# 资金地址（Safe 钱包必填！）
# 如果是 Safe 钱包，填写 Safe 钱包地址（存有资金的地址）
# 如果是普通钱包，可以留空
FUNDER_ADDRESS=0xDAe2545bB3063184ee7CEf9388cdcE1cB04e4bE4

# ==================== API 凭证 ====================
# 以下凭证由程序自动创建，无需手动填写
# 如果切换了签名类型，请删除这些值让程序重新创建
API_KEY=
API_SECRET=
PASSPHRASE=

# ==================== 交易参数 ====================
# 开仓价格 (0-100，75 表示 75%)
ENTRY_PRICE=75

# 止损价格 (0-100)
STOP_LOSS=45

# 止盈价格 (0-100)
TAKE_PROFIT=95

# 初始余额（用于仓位计算，实际余额从 API 获取）
INITIAL_BALANCE=12

# 交易周期（分钟）
TRADE_CYCLE_MINUTES=5

# 链 ID (Polygon = 137)
CHAIN_ID=137

# 日志级别
LOG_LEVEL=INFO
